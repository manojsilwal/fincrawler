API_KEY=change-me

# LLM
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=minimax/minimax-m3
LLM_FALLBACK_MODEL=minimax/minimax-m3
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.1

# Internal ASP (Phase 1–3)
ENABLE_BRIGHTDATA_PROVIDER=false
ENABLE_BROWSER_TIER4=true
ENABLE_BROWSER_GRID=true
ASP_PROVIDER_ORDER=http_impersonate,browser_grid,captcha_browser,proxy_http
PROXY_BACKEND=internal
ENABLE_INTERNAL_EGRESS=true
INTERNAL_EGRESS_ENDPOINTS=http://egress-proxy:3128
INTERNAL_EGRESS_USE_WORKER_SLOTS=true
BROWSER_PROXY_ENABLED=true
BROWSER_PROXY_MAX_RETRIES=2
PROXY_POOL_REDIS=true
CAPTCHA_PROVIDER=auto
ENABLE_ANTIBOT_SOLVER=true
ANTIBOT_PX_HOLD_MS_MIN=2800
ANTIBOT_PX_HOLD_MS_MAX=5200
ANTIBOT_MAX_ATTEMPTS=2
ANTIBOT_COOKIE_TTL_SECONDS=3600
PROVIDER_MAX_FAILURES=5
ASP_DAILY_BUDGET_USD=50
BROWSER_GRID_TIMEOUT_SECONDS=75
BROWSER_GRID_POLL_INTERVAL_MS=300
BROWSER_GRID_WORKER_CONCURRENCY=2

# Bright Data (optional — disabled until billing active)
BRIGHTDATA_API_KEY=
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE=
BRIGHTDATA_ZONE_PASSWORD=
BRIGHTDATA_SCRAPING_BROWSER_WSS=
