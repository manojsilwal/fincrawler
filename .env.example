# Copy this file to .env and fill in your values

API_KEY=change-me-to-a-strong-random-secret

# Database & queue
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/shopping_intel
REDIS_URL=redis://localhost:6379/0

# Compliant crawler identity
CRAWLER_USER_AGENT=ShoppingIntelBot/1.0 (+https://example.com/crawler-info; contact: crawler@example.com)
CRAWLER_CONTACT_EMAIL=crawler@example.com
DEFAULT_CRAWL_DELAY_SECONDS=10
MAX_REQUESTS_PER_DOMAIN_PER_MINUTE=6
FETCH_TIMEOUT_SECONDS=15

ENABLE_ALLOWED_WEB_CRAWLING=true
ENABLE_API_CONNECTORS=true
LOG_LEVEL=INFO
SNAPSHOT_DIR=data/snapshots

# Bright Data Web Unlocker (managed ASP — replaces Scrapfly for bot bypass)
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=
BRIGHTDATA_COUNTRY=us
# Optional native proxy credentials (alternative to Web Unlocker API):
# BRIGHTDATA_CUSTOMER_ID=
# BRIGHTDATA_ZONE_PASSWORD=

# Internal ASP engine (built-in anti-bot + JS render)
ENABLE_BROWSER_TIER4=true
MANAGED_FETCHER_MODE=auto
BROWSER_POOL_SIZE=2
BROWSER_NAV_TIMEOUT_MS=35000
BROWSER_HEADLESS=true
CHALLENGE_WAIT_MS=12000
MANAGED_PROXY_URL=

# ASP provider chain (comma-separated names)
ASP_PROVIDER_ORDER=browser_grid,http_impersonate,js_browser,captcha_browser,proxy_http,brightdata_scraping_browser,brightdata_unlocker,external_scrapfly
ENABLE_BRIGHTDATA_PROVIDER=true

# Proxy pool — static URLs + pluggable backends
PROXY_POOL_URLS=
PROXY_PROVIDER=auto
PROXY_BACKEND=internal
PROXY_MAX_FAILURES=3
PROXY_STICKY_SESSIONS=true
PROXY_STICKY_TTL_SECONDS=1800
PROXY_POOL_REDIS=true

# Internal self-hosted egress (Bright Data / Smartproxy alternative)
ENABLE_INTERNAL_EGRESS=true
INTERNAL_EGRESS_ENDPOINTS=http://egress-proxy:3128
INTERNAL_EGRESS_USE_WORKER_SLOTS=true
BROWSER_PROXY_ENABLED=true
BROWSER_PROXY_MAX_RETRIES=3

# Smartproxy residential (optional paid)
SMARTPROXY_USER=
SMARTPROXY_PASSWORD=
SMARTPROXY_HOST=gate.smartproxy.com
SMARTPROXY_PORT=10000

# IPRoyal residential
IPROYAL_USER=
IPROYAL_PASSWORD=
IPROYAL_HOST=geo.iproyal.com
IPROYAL_PORT=12321

# Oxylabs residential
OXYLABS_USER=
OXYLABS_PASSWORD=
OXYLABS_HOST=pr.oxylabs.io
OXYLABS_PORT=7777

# CAPTCHA solvers (CapSolver, 2Captcha)
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=
CAPTCHA_PROVIDER=auto

# Provider health / hybrid budget (Phase 2)
PROVIDER_MAX_FAILURES=5
PROVIDER_CIRCUIT_COOLDOWN_SECONDS=3600
ASP_DAILY_BUDGET_USD=0

# Browser grid — distributed Playwright workers via Redis
ENABLE_BROWSER_GRID=false
BROWSER_GRID_QUEUE_KEY=fincrawler:browser_grid:jobs
BROWSER_GRID_TIMEOUT_SECONDS=120
BROWSER_GRID_POLL_INTERVAL_MS=500

# Optional: legacy external Scrapfly API (disabled by default)
ENABLE_EXTERNAL_SCRAPFLY=false
SCRAPFLY_API_KEY=

# LLM extraction
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=minimax/minimax-m3
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.1
