# Copy this file to .env and fill in your values
# Never commit .env to git!

# ── Auth ─────────────────────────────────────────────────────────────────────
# Shared secret between FinCrawler and your finance agent app.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-strong-random-secret

# ── LLM (DeepSeek v4 Pro via NVIDIA API) ────────────────────────────────────
# Get your key at: https://integrate.api.nvidia.com
LLM_API_KEY=nvapi-your-key-here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=deepseek-ai/deepseek-v4-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── Cache ─────────────────────────────────────────────────────────────────────
# Optional: set to Cache.REDIS to use Redis instead of in-memory cache
# CACHE_BACKEND=MEMORY

# Optional Redis URL (only needed if CACHE_BACKEND=REDIS)
# REDIS_URL=redis://localhost:6379

# ── Tiered crawl (see CONTRACT.md) ───────────────────────────────────────────
# Tier 4 managed API (optional)
# SCRAPFLY_API_KEY=
# MANAGED_PROXY_URL=
