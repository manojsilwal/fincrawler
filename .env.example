# Copy this file to .env and fill in your values
# Never commit .env to git!

# Shared secret between FinCrawler and your finance agent app.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-strong-random-secret

# Optional: set to Cache.REDIS to use Redis instead of in-memory cache
# CACHE_BACKEND=MEMORY

# Optional Redis URL (only needed if CACHE_BACKEND=REDIS)
# REDIS_URL=redis://localhost:6379
