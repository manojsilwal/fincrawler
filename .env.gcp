# .env.gcp
# Production environment variables for GCP VM Deployment

# Authentication for incoming requests to FinCrawler
# Clients (like TradeTalk) must pass this in X-Api-Key or Authorization: Bearer
API_KEY=your_secure_api_key_here

# DeepSeek / NVIDIA API Key for LLM Extraction
LLM_API_KEY=your_llm_api_key_here

# Optional: Disable / Enable debug features or limits
# DEBUG=False
